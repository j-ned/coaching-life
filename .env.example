# ─── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/coaching_life
SESSION_SECRET=change_me_to_a_random_32_chars_string
PORT=3000
CORS_ORIGIN=http://localhost:4200

# ─── S3 / Garage ──────────────────────────────────────────────────────────────
S3_ENDPOINT=https://s3.example.com
S3_REGION=garage
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=coaching-img
S3_PUBLIC_URL=https://s3.example.com/coaching-img

# ─── Mail (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM="Coaching Life <noreply@example.com>"

# ─── Seed ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@coaching-life.fr
ADMIN_PASSWORD=changeme

# ─── Frontend (injecté au build CI) ───────────────────────────────────────────
API_URL=http://localhost:3000
